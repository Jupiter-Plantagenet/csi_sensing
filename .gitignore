# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/

# Packaging / tooling caches
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Jupyter
.ipynb_checkpoints/

# OS junk
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Project-specific: large data and trained weights do not belong in git
data/
*.pth
*.ckpt
*.pt
wandb/

# results/ contents are ignored by default (model checkpoints, training logs,
# plots can be heavy). The four small per-experiment artifact files mandated
# by docs/04 §7 / docs/07 — config.yaml, git_hash.txt, metrics.json, notes.md
# — are explicitly un-ignored so they end up tracked alongside the code that
# produced them.
results/**
!results/
!results/*/
!results/*/config.yaml
!results/*/git_hash.txt
!results/*/metrics.json
!results/*/notes.md
