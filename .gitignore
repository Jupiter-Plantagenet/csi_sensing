# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/

# Secrets / credentials — never commit
.env
.env.*
!.env.example
*.secret
credentials.json

# Packaging / tooling caches
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Jupyter
.ipynb_checkpoints/

# OS junk
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Project-specific: large data and trained weights do not belong in git.
# `results/<date>-<slice>-<short-description>/` is project-tracked (the four
# text files config.yaml, git_hash.txt, metrics.json, notes.md per
# `docs/07-experiment-scaffold.md`); the rules below keep large artefacts out.
data/
*.pth
*.ckpt
*.pt
wandb/
